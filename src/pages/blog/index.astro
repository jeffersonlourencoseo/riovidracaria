---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/PageHeader.astro';
import CtaBanner from '../../components/CtaBanner.astro';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date) {
  return new Intl.DateTimeFormat('pt-BR', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
  }).format(date);
}
---

<Layout
  title="Blog de Vidraçaria no Rio de Janeiro | Vidraçaria RJ"
  description="Artigos sobre vidraçaria no Rio de Janeiro: vidros temperados, box de banheiro, fechamento de sacada, Tijuca, Copacabana, Zona Norte e dicas para encontrar vidraçaria perto de mim."
  canonical="/blog/">
  <Header />
  <main class="pt-20">
    <PageHeader
      title="Blog da Vidraçaria RJ"
      subtitle="Dicas práticas, tendências e orientações para quem precisa de vidraçaria no Rio de Janeiro."
    />

    <section class="section-padding">
      <div class="container-main">
        <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="group flex flex-col rounded-2xl border border-glass-border bg-surface-card p-10 shadow-card backdrop-blur-xl transition-all duration-300 hover:-translate-y-1 hover:scale-[1.02] hover:border-primary-500/30 hover:shadow-glow"
            >
              <div class="mb-4 text-sm font-medium text-accent-400">
                {formatDate(post.data.pubDate)}
              </div>
              <h2 class="font-display text-xl font-semibold text-ink transition group-hover:text-primary-400">
                {post.data.title}
              </h2>
              <p class="mt-3 flex-grow text-ink">{post.data.description}</p>
              <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-primary-400 transition group-hover:text-accent-400">
                Ler artigo
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition group-hover:translate-x-1">
                  <path d="M5 12h14" />
                  <path d="m12 5 7 7-7 7" />
                </svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CtaBanner />
  </main>
  <Footer />
</Layout>
