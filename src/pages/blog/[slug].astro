---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/PageHeader.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { SITE_CONFIG } from '../../data/config.ts';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const canonicalUrl = `${SITE_CONFIG.url}/blog/${post.slug}/`;
const ogImage = post.data.heroImage ? `${SITE_CONFIG.url}${post.data.heroImage}` : undefined;

function formatDate(date: Date) {
  return new Intl.DateTimeFormat('pt-BR', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
  }).format(date);
}

function isoDate(date: Date) {
  return date.toISOString().split('T')[0];
}

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  image: ogImage,
  url: canonicalUrl,
  datePublished: isoDate(post.data.pubDate),
  dateModified: post.data.updatedDate ? isoDate(post.data.updatedDate) : isoDate(post.data.pubDate),
  author: {
    '@type': 'Organization',
    name: post.data.author,
    url: SITE_CONFIG.url,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE_CONFIG.name,
    logo: {
      '@type': 'ImageObject',
      url: `${SITE_CONFIG.url}/favicon.svg`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
};

const faqSchema = post.data.faq
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: post.data.faq.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    }
  : null;

const postKeywords = post.data.keywords && post.data.keywords.length > 0
  ? post.data.keywords
  : [...SITE_CONFIG.keywords, ...post.data.tags];
---

<Layout
  title={`${post.data.title} | Blog Vidraçaria RJ`}
  description={post.data.description}
  image={ogImage}
  canonical={`/blog/${post.slug}/`}
  keywords={postKeywords}>
  <Header />
  <main class="pt-20">
    <PageHeader
      title={post.data.title}
      subtitle={post.data.description}
    />

    <article class="section-padding" itemscope itemtype="https://schema.org/BlogPosting">
      <div class="container-main">
        <div class="mx-auto max-w-4xl">
          <div class="mb-8 flex flex-wrap items-center gap-4 text-sm text-ink">
            <span itemprop="datePublished" content={isoDate(post.data.pubDate)}>{formatDate(post.data.pubDate)}</span>
            <span>•</span>
            <span itemprop="author">{post.data.author}</span>
            {post.data.tags.length > 0 && (
              <>
                <span>•</span>
                <span class="flex gap-2">
                  {post.data.tags.map((tag) => (
                    <span class="rounded-full border border-glass-border bg-glass-highlight px-3 py-1 text-xs">{tag}</span>
                  ))}
                </span>
              </>
            )}
          </div>

          <div class="glass-card">
            <div class="prose prose-lg prose-invert max-w-none">
              <Content />
            </div>
          </div>
        </div>
      </div>
    </article>

    <CtaBanner />
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
</Layout>
