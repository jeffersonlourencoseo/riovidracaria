---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/PageHeader.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { SITE_CONFIG } from '../data/config.ts';

const stats = [
  { value: '10+', label: 'anos transformando ambientes com vidro' },
  { value: '15+', label: 'soluções em vidros para casa e empresa' },
  { value: '5x', label: 'mais resistência com vidro temperado' },
  { value: '0', label: 'custo no orçamento: é grátis' },
];

const values = [
  {
    title: 'Segurança em primeiro lugar',
    description:
      'Trabalhamos com vidros temperados, laminados e materiais certificados. Cada projeto é dimensionado para atender às normas técnicas e proteger quem usa.',
  },
  {
    title: 'Atendimento personalizado',
    description:
      'Cada cliente tem uma necessidade diferente. Medimos no local, ouvimos suas expectativas e indicamos a melhor solução técnica e estética.',
  },
  {
    title: 'Prazo e transparência',
    description:
      'Respeitamos o cronograma combinado e apresentamos orçamentos claros, sem taxas ocultas. Você sabe exatamente o que está contratando.',
  },
  {
    title: 'Garantia real na instalação',
    description:
      'Nossa mão de obra é especializada e todo serviço acompanha garantia. Estamos disponíveis para ajustes e dúvidas após a instalação.',
  },
];

const process = [
  {
    step: '01',
    title: 'Orçamento grátis',
    description:
      'Você entra em contato pelo WhatsApp ou formulário. Agendamos uma visita técnica para medição, sem custo e sem compromisso.',
  },
  {
    step: '02',
    title: 'Projeto e materiais',
    description:
      'Definimos juntos o tipo de vidro, espessura, acabamento e estrutura. Tudo de acordo com a aplicação, segurança e estética do ambiente.',
  },
  {
    step: '03',
    title: 'Corte e preparação',
    description:
      'Os vidros são cortados, lapidados, temperados ou laminados conforme as medidas exatas do projeto, com equipamentos de precisão.',
  },
  {
    step: '04',
    title: 'Instalação com garantia',
    description:
      'Nossa equipe instala com acabamento profissional, respeitando prazos, normas de segurança e a limpeza do local.',
  },
];

const regions = [
  { name: 'Zona Sul', examples: 'Copacabana, Ipanema, Leblon, Botafogo' },
  { name: 'Zona Norte', examples: 'Tijuca, Méier, Madureira, Penha' },
  { name: 'Centro', examples: 'Centro, Saúde, Gamboa, Santa Teresa' },
  { name: 'Zona Oeste', examples: 'Barra, Recreio, Jacarepaguá, Campo Grande' },
];

const services = [
  'Box de banheiro em vidro temperado',
  'Cortina de vidro e envidraçamento de varanda',
  'Claraboia e telhado de vidro',
  'Guarda corpo de vidro',
  'Divisórias de vidro',
  'Portas e janelas de vidro',
  'Fechamento de área com vidro',
  'Espelhos decorativos e sob medida',
  'Vidros temperados e laminados',
];
---

<Layout
  title={`Sobre | ${SITE_CONFIG.name}`}
  description={`Conheça a ${SITE_CONFIG.name}. Mais de 10 anos de experiência em vidros temperados, box, envidraçamento, guarda corpo e atendimento em todos os bairros do Rio de Janeiro.`}>
  <Header />
  <main class="pt-20">
    <PageHeader
      title={`Sobre a ${SITE_CONFIG.name}`}
      subtitle="Há mais de 10 anos transformando ambientes com vidros de qualidade, segurança e acabamento impecável no Rio de Janeiro."
    />

    <!-- Introdução + Stats -->
    <section class="section-padding">
      <div class="container-main">
        <div class="grid items-start gap-16 lg:grid-cols-2">
          <div class="space-y-6">
            <h2 class="font-display text-3xl font-black leading-tight tracking-tighter text-ink md:text-4xl">
              Vidraçaria de confiança no <span class="text-gradient">Rio de Janeiro</span>
            </h2>
            <p class="text-lg leading-relaxed text-ink">
              A <strong class="text-ink">{SITE_CONFIG.name}</strong> nasceu com um propósito claro: oferecer soluções em vidros com qualidade, segurança e atendimento personalizado para residências e comércios. Ao longo de mais de uma década, nos tornamos referência em vidraçaria na cidade do Rio de Janeiro.
            </p>
            <p class="text-ink">
              Atendemos desde pequenos reparos residenciais, como a troca de um vidro quebrado, até grandes projetos comerciais, como envidraçamento de varandas, divisórias de escritório e fachadas de vidro. Em cada serviço, aplicamos o mesmo padrão: medição precisa, produtos de qualidade, mão de obra especializada e garantia na instalação.
            </p>
            <p class="text-ink">
              Nosso diferencial está na agilidade e no compromisso com o cliente. Fazemos orçamento grátis, respeitamos prazos e acompanhamos cada etapa do projeto para garantir que o resultado final supere as expectativas.
            </p>
          </div>

          <div class="grid gap-6 sm:grid-cols-2">
            {stats.map((stat) => (
              <div class="glass-card text-center">
                <div class="text-5xl font-black text-primary-400">{stat.value}</div>
                <div class="mt-2 text-ink">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Divisor -->
    <div class="container-main">
      <hr class="border-glass-border" />
    </div>

    <!-- Missão, Visão e Valores -->
    <section class="section-padding">
      <div class="container-main">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="font-display text-3xl font-black leading-tight tracking-tighter text-ink md:text-4xl">
            Nossa missão, visão e valores
          </h2>
          <p class="mt-4 text-ink">
            Trabalhamos todos os dias para entregar vidraçaria com excelência, respeitando prazos, orçamentos e a segurança de cada ambiente.
          </p>
        </div>

        <div class="mt-16 grid gap-8 md:grid-cols-3">
          <div class="glass-card">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary-500/10 text-primary-400">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
            </div>
            <h3 class="font-display text-xl font-semibold text-ink">Missão</h3>
            <p class="mt-3 text-ink">Oferecer soluções em vidros com qualidade, segurança e atendimento diferenciado, tornando cada ambiente mais bonito, funcional e seguro.</p>
          </div>

          <div class="glass-card">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-accent-500/10 text-accent-400">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
            <h3 class="font-display text-xl font-semibold text-ink">Visão</h3>
            <p class="mt-3 text-ink">Ser a vidraçaria de referência no Rio de Janeiro, reconhecida pela excelência técnica, pontualidade e relacionamento transparente com clientes e parceiros.</p>
          </div>

          <div class="glass-card">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary-500/10 text-primary-400">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
            </div>
            <h3 class="font-display text-xl font-semibold text-ink">Valores</h3>
            <p class="mt-3 text-ink">Segurança, transparência, responsabilidade, respeito aos prazos, compromisso com o cliente e busca constante pela qualidade em cada detalhe.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Diferenciais -->
    <section class="section-padding">
      <div class="container-main">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="font-display text-3xl font-black leading-tight tracking-tighter text-ink md:text-4xl">
            O que nos diferencia
          </h2>
          <p class="mt-4 text-ink">
            Não vendemos apenas vidros. Entregamos tranquilidade, estética e durabilidade para o seu projeto.
          </p>
        </div>

        <div class="mt-16 grid gap-8 md:grid-cols-2">
          {values.map((item) => (
            <div class="glass-card">
              <h3 class="font-display text-xl font-semibold text-ink">{item.title}</h3>
              <p class="mt-3 text-ink">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Como trabalhamos -->
    <section class="section-padding">
      <div class="container-main">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="font-display text-3xl font-black leading-tight tracking-tighter text-ink md:text-4xl">
            Como trabalhamos
          </h2>
          <p class="mt-4 text-ink">
            Da primeira conversa até a instalação final, cuidamos de todo o processo para você não se preocupar com nada.
          </p>
        </div>

        <div class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
          {process.map((item) => (
            <div class="relative glass-card">
              <div class="mb-4 text-4xl font-black text-primary-400/40">{item.step}</div>
              <h3 class="font-display text-xl font-semibold text-ink">{item.title}</h3>
              <p class="mt-3 text-ink">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Cobertura -->
    <section class="section-padding">
      <div class="container-main">
        <div class="glass-card">
          <div class="grid items-center gap-12 lg:grid-cols-2">
            <div>
              <h2 class="font-display text-3xl font-black leading-tight tracking-tighter text-ink md:text-4xl">
                Atendimento em toda a cidade
              </h2>
              <p class="mt-4 text-ink">
                A {SITE_CONFIG.name} atende residências, comércios e empresas em <strong class="text-ink">todos os bairros do Rio de Janeiro</strong>. Desde a Zona Sul até a Zona Norte, passando pelo Centro, Zona Oeste e Grande Bangu.
              </p>
              <p class="mt-4 text-ink">
                Nossa equipe vai até o local para fazer a medição, entender o projeto e entregar a melhor solução em vidros. Seja um box de banheiro em Copacabana, um envidraçamento de varanda na Barra da Tijuca ou uma divisória de vidro no Centro, estamos preparados para atender.
              </p>
              <a href="/vidracaria" class="btn-primary mt-8 inline-flex">
                Ver bairros atendidos
              </a>
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              {regions.map((region) => (
                <div class="rounded-2xl border border-glass-border bg-surface-card p-6">
                  <div class="text-3xl font-black text-primary-400">{region.name}</div>
                  <p class="mt-2 text-ink">{region.examples} e mais.</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Serviços -->
    <section class="section-padding">
      <div class="container-main">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="font-display text-3xl font-black leading-tight tracking-tighter text-ink md:text-4xl">
            Principais serviços
          </h2>
          <p class="mt-4 text-ink">
            Trabalhamos com uma linha completa de produtos e serviços em vidros para atender qualquer necessidade.
          </p>
        </div>

        <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {services.map((service) => (
            <div class="flex items-center gap-3 rounded-xl border border-glass-border bg-surface-card px-5 py-4 text-ink">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-primary-400">
                <path d="M20 6 9 17l-5-5" />
              </svg>
              {service}
            </div>
          ))}
        </div>
      </div>
    </section>

    <CtaBanner />
  </main>
  <Footer />
</Layout>
