---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CtaBanner from '../components/CtaBanner.astro';

const mainServices = [
  {
    title: 'Box de Banheiro em Vidro Temperado',
    description: 'Box frontal, de canto e Blindex em vidro temperado sob medida, com ferragens cromadas, pretas ou douradas e instalação garantida.',
    href: '/servicos/box-banheiro-vidro-temperado',
    image: '/images/servicos/box-banheiro-vidro-temperado.jpg',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21h6"/><path d="M12 21v-8"/><path d="M5 13h14"/><path d="M4 13v-3a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v3"/></svg>`,
  },
  {
    title: 'Claraboia de Vidro',
    description: 'Telhados de vidro temperado que trazem luz natural e modernidade para corredores, escadas, áreas de serviço e escritórios.',
    href: '/servicos/claraboia',
    image: '/images/servicos/claraboia.jpg',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V7l8-4 8 4v14"/><path d="M12 21V11"/><path d="M12 11 8 8"/></svg>`,
  },
  {
    title: 'Cortina de Vidro',
    description: 'Envidraçamento de varanda com painéis de vidro temperado deslizantes, permitindo abertura total e proteção contra vento e chuva.',
    href: '/servicos/cortina-envidracamento-varanda',
    image: '/images/servicos/cortina-envidracamento-varanda.jpg',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="3" x2="21" y2="21"/></svg>`,
  },
];
---

<Layout
  title="Vidraçaria RJ | Vidros Temperados e Serviços de Vidraçaria no Rio de Janeiro"
  description="Vidraçaria RJ: orçamento grátis, instalação com garantia e mais de 10 anos de experiência em vidros temperados, box, fechamento de área e envidraçamento no Rio de Janeiro.">
  <Header />
  <main class="pt-20">
    <Hero />

    <Section
      title="Serviços de vidraçaria no Rio de Janeiro"
      subtitle="Três das nossas soluções mais procuradas. Na página de serviços você encontra todas as opções para residências e comércios."
      centered={true}
      light={true}
    >
      <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3">
        {mainServices.map((service) => (
          <ServiceCard {...service} />
        ))}
      </div>

      <div class="mt-14 flex justify-center">
        <a href="/servicos" class="btn-secondary inline-flex items-center gap-2">
          Ver todos os serviços
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>
    </Section>

    <Section
      title="Por que escolher a Vidraçaria RJ?"
      subtitle="Trabalhamos com transparência, prazo e compromisso para entregar o melhor resultado em cada projeto."
      centered={true}
    >
      <div class="grid gap-10 md:grid-cols-3">
        <div class="glass-card">
          <div class="mb-4 text-4xl font-black text-primary-400">10+</div>
          <h3 class="font-display text-xl font-semibold text-ink">Vidraçaria com experiência</h3>
          <p class="mt-3 text-ink">Mais de uma década instalando vidros temperados em residências e comércios do Rio de Janeiro.</p>
        </div>
        <div class="glass-card">
          <div class="mb-4 text-4xl font-black text-accent-400">0%</div>
          <h3 class="font-display text-xl font-semibold text-ink">Orçamento grátis de vidraçaria</h3>
          <p class="mt-3 text-ink">Orçamento sem compromisso. Você só decide após conhecer nossas condições para vidros e box.</p>
        </div>
        <div class="glass-card">
          <div class="mb-4 text-4xl font-black text-primary-400">Garantia</div>
          <h3 class="font-display text-xl font-semibold text-ink">Instalação segura de vidros</h3>
          <p class="mt-3 text-ink">Mão de obra especializada e garantia na instalação de vidro temperado para sua tranquilidade.</p>
        </div>
      </div>
    </Section>

    <CtaBanner />
  </main>
  <Footer />
</Layout>
