---
import { SITE_CONFIG } from '../data/config.ts';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${SITE_CONFIG.url}/#localbusiness`,
  name: SITE_CONFIG.name,
  description: SITE_CONFIG.tagline,
  url: SITE_CONFIG.url,
  telephone: `+55 ${SITE_CONFIG.phone.replace(/\D/g, '')}`,
  email: SITE_CONFIG.email,
  image: `${SITE_CONFIG.url}/images/servicos/box-banheiro-vidro-temperado.jpg`,
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE_CONFIG.address,
    addressLocality: SITE_CONFIG.city,
    addressRegion: SITE_CONFIG.state,
    addressCountry: SITE_CONFIG.country,
    postalCode: SITE_CONFIG.postalCode,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: SITE_CONFIG.geo.latitude,
    longitude: SITE_CONFIG.geo.longitude,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '08:00',
      closes: '18:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Saturday',
      opens: '08:00',
      closes: '12:00',
    },
  ],
  areaServed: {
    '@type': 'City',
    name: SITE_CONFIG.city,
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
