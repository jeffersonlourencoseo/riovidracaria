---
import { SITE_CONFIG } from '../data/config.ts';
---

<section class="relative min-h-screen overflow-hidden bg-surface pt-32 pb-24 lg:pt-40 lg:pb-32">
  <!-- Fundo com grid e brilhos -->
  <div class="absolute inset-0 bg-hero-glow"></div>
  <div
    class="absolute inset-0 opacity-[0.10]"
    style="background-image: linear-gradient(rgba(56,189,248,0.12) 1px, transparent 1px), linear-gradient(90deg, rgba(56,189,248,0.12) 1px, transparent 1px); background-size: 80px 80px;"
  ></div>
  <div class="absolute top-1/4 right-0 h-[600px] w-[600px] -translate-y-1/2 translate-x-1/3 rounded-full bg-primary-500/20 blur-[120px]"></div>
  <div class="absolute bottom-0 left-0 h-[500px] w-[500px] -translate-x-1/3 translate-y-1/3 rounded-full bg-accent-500/15 blur-[100px]"></div>

  <div class="container-main relative">
    <div class="grid items-center gap-16 lg:grid-cols-2">
      <div class="max-w-2xl">
        <span class="animate-fade-up inline-flex items-center gap-2 rounded-full border border-glass-border bg-glass-highlight px-4 py-1.5 text-sm font-medium text-primary-400">
          <span class="h-2 w-2 rounded-full bg-accent-400"></span>
          Mais de 10 anos no Rio de Janeiro
        </span>

        <h1 class="animate-fade-up delay-100 mt-8 font-display text-4xl font-black leading-tight tracking-tighter text-ink sm:text-5xl md:text-6xl lg:text-6xl">
          Vidros temperados com <span class="text-gradient">precisão</span> e garantia
        </h1>

        <p class="animate-fade-up delay-200 mt-6 text-lg leading-relaxed text-ink md:text-xl">
          Procurando uma {SITE_CONFIG.keyword.replace(' perto de mim', '')} confiável no Rio de Janeiro? Fazemos orçamento grátis,
          instalamos com garantia e atendemos residências e comércios em toda a cidade.
        </p>

        <div class="animate-fade-up delay-300 mt-10 flex flex-wrap items-center gap-4">
          <a
            href={`https://wa.me/${SITE_CONFIG.whatsapp}?text=Olá! Gostaria de um orçamento grátis.`}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            Pedir orçamento grátis
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </a>
          <a href="/servicos" class="btn-secondary">
            Ver serviços
          </a>
        </div>

        <div class="animate-fade-up delay-400 mt-14 flex flex-wrap gap-8 text-sm font-medium text-ink">
          {SITE_CONFIG.differentials.map((item) => (
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2DD4BF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6 9 17l-5-5" />
              </svg>
              {item}
            </div>
          ))}
        </div>
      </div>

      <!-- Visual geométrico de vidro -->
      <div class="animate-fade-up delay-500 relative hidden lg:block">
        <div class="relative mx-auto aspect-square w-full max-w-lg">
          <div class="absolute inset-0 rounded-[3rem] border border-glass-border bg-surface-card p-[1px] shadow-card backdrop-blur-2xl">
            <div class="absolute inset-0 rounded-[3rem] bg-gradient-to-br from-primary-500/10 via-transparent to-accent-500/10"></div>
            <div class="absolute inset-4 rounded-[2.5rem] border border-glass-border bg-glass-highlight p-8 backdrop-blur-xl">
              <div class="grid h-full grid-cols-2 gap-4">
                <div class="rounded-2xl border border-glass-border bg-surface-card p-6">
                  <div class="text-4xl font-black text-primary-400">10+</div>
                  <div class="mt-2 text-sm text-ink">anos no mercado</div>
                </div>
                <div class="rounded-2xl border border-glass-border bg-surface-card p-6">
                  <div class="text-4xl font-black text-accent-400">24h</div>
                  <div class="mt-2 text-sm text-ink">orçamento rápido</div>
                </div>
                <div class="col-span-2 rounded-2xl border border-glass-border bg-surface-card p-6">
                  <div class="flex items-center justify-between">
                    <div>
                      <div class="text-sm text-ink">Atendimento</div>
                      <div class="mt-1 text-xl font-semibold text-ink">Rio de Janeiro - RJ</div>
                    </div>
                    <div class="h-12 w-12 rounded-full bg-gradient-to-br from-primary-500 to-accent-500 shadow-glow"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="absolute -right-8 top-1/4 h-40 w-40 rounded-full border border-glass-border bg-surface-card p-4 shadow-glow backdrop-blur-xl">
            <div class="h-full w-full rounded-full bg-gradient-to-br from-primary-500/20 to-transparent"></div>
          </div>
          <div class="absolute -bottom-6 -left-6 h-32 w-32 rounded-2xl border border-glass-border bg-surface-card p-3 shadow-glow-accent backdrop-blur-xl">
            <div class="h-full w-full rounded-xl bg-gradient-to-br from-accent-500/20 to-transparent"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
