---
export interface Props {
  title: string;
  description: string;
  icon: string;
  image?: string;
  href?: string;
}

const { title, description, icon, image, href = '/' } = Astro.props;
---

<a
  href={href}
  class="group relative flex flex-col overflow-hidden rounded-2xl border border-glass-border bg-surface-card p-10 shadow-card backdrop-blur-xl transition-all duration-300 hover:-translate-y-1 hover:scale-[1.02] hover:border-primary-500/30 hover:shadow-glow"
>
  <div class="absolute inset-0 rounded-2xl bg-card-shine opacity-0 transition duration-500 group-hover:opacity-100"></div>
  <div class="absolute -inset-px rounded-2xl bg-gradient-to-r from-primary-500/0 via-primary-500/0 to-accent-500/0 opacity-0 blur transition duration-500 group-hover:from-primary-500/10 group-hover:via-primary-500/5 group-hover:to-accent-500/10 group-hover:opacity-100"></div>

  {image && (
    <div class="relative -mx-10 -mt-10 mb-8 aspect-video overflow-hidden">
      <img
        src={image}
        alt={title}
        loading="lazy"
        class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-surface-card/80 via-surface-card/20 to-transparent"></div>
    </div>
  )}

  <div class="relative mb-6 flex h-14 w-14 items-center justify-center rounded-xl border border-glass-border bg-glass-highlight text-primary-400 transition duration-300 group-hover:border-primary-500/30 group-hover:text-accent-400">
    <Fragment set:html={icon} />
  </div>

  <div class="relative">
    <h3 class="font-display text-xl font-semibold text-ink">{title}</h3>
    <p class="mt-3 leading-relaxed text-ink">{description}</p>
    <span class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-primary-400 transition group-hover:text-accent-400">
      Ver serviço
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition duration-300 group-hover:translate-x-1">
        <path d="M5 12h14" />
        <path d="m12 5 7 7-7 7" />
      </svg>
    </span>
  </div>
</a>
